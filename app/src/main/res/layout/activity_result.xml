<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="120dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <View
                android:id="@+id/header_result"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:background="@drawable/bg_header_rounded"
                app:layout_constraintTop_toTopOf="parent"/>

            <ImageView
                android:id="@+id/iv_header_icon"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_check_circle"
                app:tint="@color/white"
                android:layout_marginTop="56dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <TextView
                android:id="@+id/tvDateDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="10 Mar 2026"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@+id/iv_header_icon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/card_white"
                app:layout_constraintTop_toBottomOf="@id/tvDateDetail">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_durasi_tidur"
                        android:textColor="@color/text_sub"
                        android:layout_gravity="center"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/tvDurationDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="07 Jam 30 Menit"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_main"
                        android:layout_gravity="center"
                        android:layout_marginTop="8dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/border_divider"
                        android:layout_marginVertical="24dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:baselineAligned="false">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/jam_tidur"
                                android:textSize="12sp"
                                android:textColor="@color/text_sub"/>
                            <TextView
                                android:id="@+id/tvTimeRange"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                tools:text="23:00 – 06:00"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_main"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/kualitas"
                                android:textSize="12sp"
                                android:textColor="@color/text_sub"/>
                            <TextView
                                android:id="@+id/tvQualityDetail"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                tools:text="Sangat Baik"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/success_green"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_recommendation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/card_white"
                app:layout_constraintTop_toBottomOf="@id/card_summary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/rekomendasi_pakar"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_main"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:id="@+id/tvRecommendationDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/memuat_saran"
                        android:textSize="15sp"
                        android:lineSpacingExtra="6dp"
                        android:textColor="@color/text_main"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_restbot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/sleep_accent_light"
                app:strokeWidth="1dp"
                app:strokeColor="@color/sleep_accent"
                app:layout_constraintTop_toBottomOf="@id/card_recommendation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:id="@+id/iv_bot_icon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_restbot"
                        android:background="@color/white"
                        android:padding="8dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:id="@+id/tv_bot_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/tanya_restbot_ai"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/sleep_primary" />

                        <TextView
                            android:id="@+id/tv_bot_desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/konsultasi_restbot_desc"
                            android:textSize="12sp"
                            android:textColor="@color/text_sub"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                android:text="@string/kembali_ke_dashboard"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/sleep_primary"
                app:cornerRadius="16dp"
                app:layout_constraintTop_toBottomOf="@id/card_restbot" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>