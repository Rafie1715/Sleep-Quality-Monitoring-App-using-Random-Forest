<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="@color/border_divider"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/apa_itu_kalkulator_sks"
            android:textColor="@color/text_main"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/kalkulator_sks_sistem_kebut_semalam_adalah_fitur_harm_reduction_yang_dirancang_khusus_untuk_mahasiswa_yang_terpaksa_tidur_dalam_waktu_singkat_fitur_ini_mencari_waktu_bangun_emas_agar_kamu_terhindar_dari_rasa_pening_dan_linglung_saat_bangun"
            android:textColor="@color/text_sub"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dasar_teori_medis"
            android:textColor="@color/text_main"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/_1_siklus_tidur_90_menit_ntidur_manusia_melewati_siklus_nrem_tidur_ringan_ke_nyenyak_dan_rem_mimpi_satu_siklus_penuh_membutuhkan_rata_rata_90_menit_jika_kamu_bangun_tepat_di_akhir_siklus_fase_tidur_ringan_tubuh_akan_terasa_jauh_lebih_segar_dibandingkan_jika_kamu_terbangun_di_tengah_fase_deep_sleep_nrem_3_n_n2_sleep_inertia_kelambanan_tidur_nbangun_secara_paksa_di_fase_deep_sleep_akan_memicu_sleep_inertia_kondisi_neurologis_di_mana_otak_belum_siap_sadar_menyebabkan_disorientasi_kepala_berat_dan_penurunan_memori_kalkulator_ini_mencegah_hal_tersebut_n_n3_waktu_latensi_15_menit_nrata_rata_manusia_sehat_membutuhkan_waktu_15_hingga_20_menit_untuk_benar_benar_tertidur_sejak_memejamkan_mata_sleep_latency"
            android:textColor="@color/text_sub"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sumber_referensi"
            android:textColor="@color/success_green"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/national_institutes_of_health_nih_brain_basics_understanding_sleep_n_sleep_foundation_what_is_sleep_inertia_n_harvard_medical_school_the_importance_of_sleep_cycles"
            android:textColor="@color/text_sub"
            android:textSize="12sp"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMengerti"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/saya_mengerti"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:backgroundTint="@color/sleep_primary"
            app:cornerRadius="16dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>