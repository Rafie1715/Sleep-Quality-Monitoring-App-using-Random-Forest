<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#1E1E1E"> <View
    android:layout_width="40dp"
    android:layout_height="4dp"
    android:layout_gravity="center_horizontal"
    android:background="#555555"
    android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sains di Balik Kalkulator SKS 🔬"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mengapa tidur sebentar terkadang terasa lebih segar daripada tidur lama?"
        android:textColor="#4CAF50"
        android:textStyle="italic"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1. Teori Siklus 90 Menit"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tidur manusia tidak berjalan datar, melainkan bergelombang. Satu siklus tidur penuh (dari tidur ringan, nyenyak/Deep Sleep, hingga mimpi/REM) rata-rata memakan waktu 90 menit (1,5 jam)."
        android:textColor="#BBBBBB"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2. Menghindari Sleep Inertia"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jika alarm berbunyi tepat saat kamu berada di fase Deep Sleep, kamu akan mengalami Sleep Inertia (bangun dengan kepala berat dan linglung). Kalkulator ini mencari waktu di mana siklus 90 menitmu berakhir, sehingga kamu bangun di fase tidur ringan."
        android:textColor="#BBBBBB"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3. Mengapa ditambah 15 menit?"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rata-rata orang dewasa membutuhkan waktu sekitar 15 menit sejak memejamkan mata hingga benar-benar tertidur (Sleep Latency). Aplikasi secara otomatis menambahkan waktu ini agar perhitungannya presisi."
        android:textColor="#BBBBBB"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnMengerti"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="SAYA MENGERTI"
        app:cornerRadius="12dp" />

</LinearLayout>