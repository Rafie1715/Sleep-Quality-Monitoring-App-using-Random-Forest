<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.RestUPSkripsiRafieRojagatBachri" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg_light</item>
        <item name="colorPrimary">@color/sleep_primary</item>
        <item name="colorAccent">@color/sleep_accent</item>
    </style>

    <style name="Theme.RestUPSkripsiRafieRojagatBachri" parent="Base.Theme.RestUPSkripsiRafieRojagatBachri" />

    <style name="CircleImage" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
